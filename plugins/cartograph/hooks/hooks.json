{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(*graph_build*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/graph_community_refresh.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
