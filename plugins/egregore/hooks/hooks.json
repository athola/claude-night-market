{
  "hooks": {
    "Stop": [
      {
        "_comment": "Block exit when egregore has active work items",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/stop_hook.py",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "_comment": "Resume egregore orchestration on session start",
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/session_start_hook.py",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_comment": "Inject orchestration-resume context when user interrupts an active egregore session",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_hook.py",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
